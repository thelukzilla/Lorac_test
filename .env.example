# Copie este arquivo para .env ao rodar localmente.
# O app abre sem essas chaves; apenas IA e chamadas ao vivo ficam indisponiveis.

LORAC_CORS_ORIGINS=*

# Cohere habilita /api/ai/chat, /api/ai/corrigir e /api/ai/gerar-questoes.
COHERE_API_KEY=

# LiveKit habilita chamadas de audio/video nas salas.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Plataformas como Render/Railway definem PORT automaticamente.
PORT=8000
